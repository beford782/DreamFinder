# ===========================================
# AI Search for Business Central - Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Business Central (On-Premises) ---
# The base URL of your BC server's OData v4 endpoint, e.g.:
#   https://server:7048/BC/ODataV4
#   https://server:7048/BC250/ODataV4
#   http://server:7048/BC/ODataV4
BC_SERVER_URL=https://your-server:7048/BC/ODataV4

# Your BC username (typically DOMAIN\username)
BC_USERNAME=DOMAIN\username

# Your Web Service Access Key (found in BC: user settings → Web Service Access Key)
BC_WEB_SERVICE_KEY=your-web-service-access-key

# Company name in BC (exact match, e.g. "CROSLEY COMPANY" or "Bel Furniture")
BC_COMPANY_NAME=Your Company Name

# --- Server ---
PORT=3000
